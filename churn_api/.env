# ----- Modelo --------------------------------------------------------------
MODEL_PATH=modelos/churn_model.joblib
MODEL_META_PATH=modelos/churn_model.meta.json

# ----- Faixas de risco (privilegiam recall; ver doc, seção 7.3) ------------
LIMIAR_ALTO=0.50
LIMIAR_MEDIO=0.30

# ----- MongoDB Atlas -------------------------------------------------------
# MONGO_URI=mongodb+srv://<db_username>:<db_password>...
MONGO_DB=churn
MONGO_TLS=auto
MONGO_TIMEOUT_MS=8000
MONGO_BATCH=5000

# ----- Redis (cache; opcional nesta etapa) ---------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=2592000

# ----- API -----------------------------------------------------------------
API_TOKEN=
ALTO_RISCO_LIMIT=100
